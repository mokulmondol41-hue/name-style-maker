<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Top Row: Styled Name Text -->
        <TextView
            android:id="@+id/tv_styled_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Mukul ⚡"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textIsSelectable="true"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <!-- Bottom Row Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_variant"
            android:layout_marginBottom="8dp" />

        <!-- Bottom Row: Action Icons -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Subtitle/Details or blank -->
            <TextView
                android:id="@+id/tv_style_index"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Style #1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Buttons on the far right -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Favorite Button -->
                <ImageButton
                    android:id="@+id/btn_style_favorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Favorite style"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_favorite_border"
                    android:tint="@color/accent_blue" />

                <!-- Share Button -->
                <ImageButton
                    android:id="@+id/btn_style_share"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Share style"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_share"
                    android:tint="@color/accent_blue" />

                <!-- Copy Button -->
                <ImageButton
                    android:id="@+id/btn_style_copy"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Copy style"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_copy"
                    android:tint="@color/accent_blue" />

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
